# ======================== Data & Models ========================
# Large model weights (download from Google Drive)
*.pt
*.ckpt
*.h5
*.hdf5
*.pkl
*.pickle

# Model weights are too large for git - download from Google Drive
# See README.md for download links
models/

# Datasets (should be downloaded separately)
data/
datasets/
cifar-10-*/
ILSVRC/
imagenet/
ImageNet/

# Experiment outputs (generated during training)
experiments/
results/
outputs/
logs/
runs/

# ======================== Project Specific ========================
# Generated checkpoints during training (but keep the ones in models/)
checkpoints/

# Downloaded pretrained colorization models
*.caffemodel

# Colorization demo outputs
colorization_results/
demo_outputs/
comparison_outputs/

# Large result files
*.json.bak
evaluation_results/
analysis_results/

# Temporary files
*.tmp
*.temp
*.bak
*.log

# ======================== Media ========================
